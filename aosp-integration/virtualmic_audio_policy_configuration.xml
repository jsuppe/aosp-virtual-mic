<!-- Virtual Microphone Audio Policy Configuration file -->
<module name="virtualmic" halVersion="2.0">
    <attachedDevices>
        <item>Virtual Mic In</item>
    </attachedDevices>
    <mixPorts>
        <mixPort name="virtualmic input" role="sink">
           <profile name="" format="AUDIO_FORMAT_PCM_16_BIT"
                    samplingRates="48000" channelMasks="AUDIO_CHANNEL_IN_STEREO"/>
        </mixPort>
   </mixPorts>
   <devicePorts>
       <devicePort tagName="Virtual Mic In" type="AUDIO_DEVICE_IN_BUILTIN_MIC" role="source">
           <profile name="" format="AUDIO_FORMAT_PCM_16_BIT"
                    samplingRates="48000" channelMasks="AUDIO_CHANNEL_IN_STEREO"/>
        </devicePort>
    </devicePorts>
    <routes>
        <route type="mix" sink="virtualmic input"
               sources="Virtual Mic In"/>
    </routes>
</module>
