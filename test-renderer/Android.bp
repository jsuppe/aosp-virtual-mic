// Virtual Mic Test Renderer
//
// Vendor daemon that generates a 440 Hz sine tone and streams it into
// the virtual mic HAL via shared memory. Runs in its own SELinux domain
// (virtualmic_renderer) so it can legally connect to the HAL's Unix
// socket — core-to-vendor socket connections are blocked by Treble.

cc_binary {
    name: "virtualmic-renderer",
    srcs: ["virtual_mic_renderer.cpp"],

    init_rc: ["virtualmic-renderer.rc"],

    cflags: [
        "-Wall",
        "-Werror",
        "-Wno-unused-parameter",
    ],

    shared_libs: [
        "liblog",
        "libcutils",
    ],

    vendor: true,
}
