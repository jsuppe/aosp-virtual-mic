<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VMic Test"
        android:textSize="24sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#16213e" />

    <!-- Sending frequency (what renderer is outputting) -->
    <TextView
        android:id="@+id/sendingText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sending: -- Hz"
        android:textColor="#FF9800"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="4dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="#888888"
        android:textSize="14sp"
        android:padding="8dp" />

    <!-- Frequency display (big) -->
    <TextView
        android:id="@+id/frequencyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Freq: -- Hz"
        android:textColor="#00E676"
        android:textSize="42sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp" />

    <!-- Amplitude info -->
    <TextView
        android:id="@+id/amplitudeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RMS: -- dB, Peak: --"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="8dp" />

    <!-- Waveform visualization -->
    <com.example.vmictest.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#0f0f1a" />

    <!-- Simple level meter -->
    <ProgressBar
        android:id="@+id/levelMeter"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#00BCD4"
        android:layout_marginTop="8dp" />

    <!-- Alignment metrics -->
    <TextView
        android:id="@+id/alignmentText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Correlation: --, Phase: --"
        android:textColor="#00BCD4"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="4dp" />

    <!-- Legend -->
    <TextView
        android:id="@+id/waveformText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Green = expected | Cyan = actual"
        android:textColor="#666666"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <!-- Button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Record button -->
        <Button
            android:id="@+id/recordButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="RECORD"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginEnd="2dp" />

        <!-- Demo button -->
        <Button
            android:id="@+id/demoButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="DEMO"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" />

        <!-- Latency test button -->
        <Button
            android:id="@+id/latencyButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="LATENCY"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9C27B0"
            android:layout_marginStart="2dp" />
    </LinearLayout>

</LinearLayout>
</ScrollView>
