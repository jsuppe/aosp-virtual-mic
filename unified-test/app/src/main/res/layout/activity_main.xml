<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a2e">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VMic Test"
        android:textSize="24sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#16213e" />

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="#888888"
        android:textSize="14sp"
        android:padding="8dp" />

    <!-- Frequency display (big) -->
    <TextView
        android:id="@+id/frequencyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Freq: -- Hz"
        android:textColor="#00E676"
        android:textSize="48sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp" />

    <!-- Amplitude info -->
    <TextView
        android:id="@+id/amplitudeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RMS: -- dB, Peak: --"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="8dp" />

    <!-- Waveform visualization -->
    <com.example.vmictest.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#0f0f1a" />

    <!-- Simple level meter -->
    <ProgressBar
        android:id="@+id/levelMeter"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#00BCD4"
        android:layout_marginTop="8dp" />

    <!-- Expected frequency indicator -->
    <TextView
        android:id="@+id/waveformText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Expected: 440 Hz sine wave\n(green = match, red = mismatch)"
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Record button -->
    <Button
        android:id="@+id/recordButton"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="RECORD"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50" />

</LinearLayout>
